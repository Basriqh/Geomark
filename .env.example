# ──────────────────────────────────────────────────────────────
# GEOMARK Engineering Consultants — Environment Variables
# Copy this file to .env.local for local development.
# On Hostinger: set these in the "Environment Variables" panel.
# Never commit .env.local to source control.
# ──────────────────────────────────────────────────────────────

# Public site URL (used in sitemap / canonical URLs)
APP_URL="https://www.geomark.so"

# ── Contact Form (SMTP) ────────────────────────────────────────
# Configure an SMTP relay (e.g. SendGrid, Mailgun, AWS SES) so
# the /api/contact route can send emails.
# If these are blank, inquiries are only logged to stdout.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="no-reply@geomark.so"
SMTP_PASS="your-smtp-password"

# Destination inbox for inbound contact form submissions
CONTACT_EMAIL="info@geomark.so"
